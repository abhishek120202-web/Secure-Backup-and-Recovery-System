# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Application Secret Key
SECRET_KEY=your-secret-key-change-this-in-production

# Database Configuration
# For MySQL: mysql+pymysql://username:password@localhost:3306/database_name
DEV_DATABASE_URL=mysql+pymysql://root:password@localhost:3306/secure_backup_dev
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/secure_backup_prod

# File Storage
BACKUP_FOLDER=backups/
UPLOAD_FOLDER=uploads/

# Logging
LOG_TO_STDOUT=True
LOG_LEVEL=DEBUG

# Retention Policies (in days)
BACKUP_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365

# Mail Server (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Security
AES_KEY_LENGTH=256
HASH_ALGORITHM=sha256
